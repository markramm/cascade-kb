# Front-end Caddyfile snippet for capturecascade.org.
#
# This is the block that lives in the SHARED front-end Caddy (the one that
# also serves demo.pyrite.wiki and journalists.pyrite.wiki). On the VPS it's
# at /home/deploy/pyrite/deploy/demo/Caddyfile.
#
# This snippet documents what the live config should contain after the static
# migration. The actual edit is performed by deploy/deploy.sh which patches
# the running file in place.

# www → non-www, collapsing the legacy plural/section paths in the SAME hop.
#
# Why this is more than a host strip: Google's "Not found (404)" report is
# entirely www URLs of the form www.capturecascade.org/events/<slug>/ (plural).
# A bare host-strip redirect (redir …{uri}) preserves the plural path, so the
# URL then needs a SECOND redirect (/events/→/event/) from the inner Caddy —
# a 2–3 hop chain Google declines to consolidate, leaving the old URL logged
# as 404. By normalizing the path here we emit a single 301 straight to the
# canonical non-www singular URL, which consolidates cleanly.
#
# Most specific path match first; the final handle is the catch-all host strip.
www.capturecascade.org {
    # Legacy plural / section path normalizations → canonical singular.
    @ev    path_regexp ev    ^/events(/.*)?$
    @site  path_regexp site  ^/site/cascade-timeline(/.*)?$
    @siteroot path /site /site/

    handle @site {
        redir https://capturecascade.org/event{re.site.1} permanent
    }
    handle @siteroot {
        redir https://capturecascade.org/ permanent
    }
    handle @ev {
        redir https://capturecascade.org/event{re.ev.1} permanent
    }
    # Everything else: strip www only, preserve path.
    handle {
        redir https://capturecascade.org{uri} permanent
    }
}

capturecascade.org {
    # Reverse-proxy to the cascade-static container (Caddy serving Hugo output)
    reverse_proxy cascade:8088

    # The inner Caddy in the cascade container handles caching, compression,
    # security headers, and the custom 404 — see deploy/Caddyfile.container.
    # Front-end Caddy just terminates TLS and forwards.
}
