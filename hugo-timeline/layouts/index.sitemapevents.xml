<?xml version="1.0" encoding="utf-8" standalone="yes"?>
{{/* lastmod sourced from data/lastmod.json (per-event git commit time,
     pre-validated by scripts/generate_content.py). Falls back to build
     time only if the slug is missing from the map. Google rejects
     pre-1970 lastmod values; the generator already filters those out. */}}
{{- $buildtime := now.Format "2006-01-02T15:04:05-07:00" -}}
{{- $lastmod := site.Data.lastmod -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- range where site.RegularPages "Type" "event" }}
  {{- $slug := .File.ContentBaseName -}}
  {{- $when := index $lastmod $slug | default $buildtime -}}
  <url>
    <loc>{{ .Permalink }}</loc>
    <lastmod>{{ $when | safeHTML }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
{{- end }}
</urlset>
